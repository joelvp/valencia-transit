{
  "name": "valencia-transit",
  "version": "0.1.0",
  "description": "Transit information system for Valencia's metro network",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/main.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "import:gtfs": "bun run scripts/import-gtfs.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "grammy": "^1.41.1",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-hexagonal-architecture": "^1.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
